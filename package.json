{
  "name": "katsu-electron",
  "version": "0.0.0",
  "private": true,
  "author": "thePrnvBot",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "run-p dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "pnpm transpile:electron && cross-env NODE_ENV=development electron .",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "transpile:electron": "tsc --project src/electron/tsconfig.json",
    "dist:mac": "pnpm transpile:electron && pnpm build && electron-builder --mac --arm64",
    "dist:win": "pnpm transpile:electron && pnpm build && electron-builder --win --x64",
    "dist:linux": "pnpm transpile:electron && pnpm build && electron-builder --linux --x64",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@gorhill/ubo-core": "^0.1.30",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "effect": "^3.21.4",
    "geist": "^1.7.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-rnd": "^10.5.3",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "husky": "^9.1.7",
    "knip": "^6.26.0",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "ultracite": "7.9.3",
    "vite": "^8.1.1"
  }
}
